# --- App ---
NODE_ENV=development
APP_BASE_URL=http://localhost:4000
APP_PORT=4000
CORS_ORIGINS=http://localhost:3000

# --- Postgres ---
DATABASE_URL=postgresql://wallet:wallet@localhost:5432/wallet_finanzas?schema=public

# --- JWT auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-too-different-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# --- Encryption for stored secrets (BYOK AI keys, future bank tokens) ---
# Must be 32 bytes hex (64 chars). Generate: openssl rand -hex 32
MASTER_KEY=

# --- MinIO / S3-compatible (receipts) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=wallet-receipts
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=true

# --- Redis (BullMQ jobs, future) ---
REDIS_URL=redis://localhost:6379

# --- External services (rate fetchers, no auth needed for these) ---
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
BINANCE_P2P_BASE_URL=https://p2p.binance.com/bapi/c2c/v2
